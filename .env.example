# Vriksh Cloud - Environment Template

# Core Routing
PUBLIC_HOST=console.vriksh.cloud

# Identity / Keycloak
SSO_BASE_URL=https://sso.vriksh.cloud
KEYCLOAK_REALM=vriksh
KEYCLOAK_CLIENT_ID=vriksh-console
KEYCLOAK_CLIENT_SECRET=vriksh-secret-1234

# Docker Engine Access
# (Map /var/run/docker.sock into container to allow lab orchestration)
DOCKER_HOST=unix:///var/run/docker.sock

# Stripe Billing Integration
# (Use Sandbox 'sk_test_' for development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Cloudflare (For TLS/DNS Automation)
CLOUDFLARE_VRIKSH_API_TOKEN=cfut_...
ACME_EMAIL=admin@vriksh.cloud
